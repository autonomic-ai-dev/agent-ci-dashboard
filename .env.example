# =============================================
# Agent CI Dashboard — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ------------------------------------------------------------------
# GitHub Personal Access Token
# Required: repo, workflow scopes
# Create at: https://github.com/settings/tokens
# ------------------------------------------------------------------
GITHUB_TOKEN=github_pat_REPLACE_ME

# ------------------------------------------------------------------
# Auth.js Configuration
# AUTH_SECRET: Run `openssl rand -base64 32` to generate
# ------------------------------------------------------------------
AUTH_SECRET="REPLACE_ME_run_openssl_rand_base64_32"
AUTH_URL="http://localhost:5173"

# ------------------------------------------------------------------
# GitHub OAuth App
# Create at: https://github.com/settings/applications/new
# Local callback URL:      http://localhost:5173/auth/callback/github
# Production callback URL: https://agent-ci-dashboard.vercel.app/auth/callback/github
# ------------------------------------------------------------------
GITHUB_CLIENT_ID="REPLACE_ME"
GITHUB_CLIENT_SECRET="REPLACE_ME"

# ------------------------------------------------------------------
# VAPID Keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
# ------------------------------------------------------------------
PUBLIC_VAPID_KEY="REPLACE_ME_public_vapid_key"
VAPID_PRIVATE_KEY="REPLACE_ME_private_vapid_key"

# ------------------------------------------------------------------
# Webhook Secret for GitHub Webhook signature verification
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------------
WEBHOOK_SECRET="REPLACE_ME_run_openssl_rand_hex_32"

# ------------------------------------------------------------------
# Vercel KV (Redis) — auto-injected when you link a KV database
# ------------------------------------------------------------------
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ------------------------------------------------------------------
# Rust gRPC Backend — URL for the insights-api service
# Local: http://localhost:3002
# Production: https://insights-api.onrender.com (or your deployed URL)
# ------------------------------------------------------------------
VITE_GRPC_API_URL="http://localhost:3002"

# =============================================
# Rust Backend (insights-api / github-ingestor)
# =============================================

# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# GitHub token for API calls (used as fallback when no user session token)
GITHUB_TOKEN_BACKEND=github_pat_REPLACE_ME

# Webhook secret (must match GitHub webhook config)
GITHUB_WEBHOOK_SECRET=REPLACE_ME_run_openssl_rand_hex_32

# Optional: ingestor listens on 3001, api on 3002 by default
# INGESTOR_PORT=3001
# API_PORT=3002
